{
    "app_name": "VAN/PG 모니터링 대시보드",
    "version": "1.0.0",
    "window": {
        "width": 1100,
        "height": 700
    },
    "refresh": {
        "interval_ms": 5000,
        "auto_start": true
    },
    "org_list": [
        "전체", "KBC", "BCC", "HDC", "SHC", "HNC", "SSC", "NCV", "WRC", "KEC", "LTC", "CNS"
    ],
    "alarm_types": [
        "전체", "타임아웃", "지연응답", "회원사장애", "중복거절", "배치", "SAF", "0800전문", "프로세스", "대행승인", "core파일"
    ],
    "snooze": {
        "default_minutes": 10,
        "options": [5, 10, 30, 60]
    },
    "shortcuts": {
        "start_monitoring": "F5",
        "stop_monitoring": "F6",
        "test_data": "F7",
        "export_excel": "Ctrl+E",
        "toggle_pause": "Ctrl+P",
        "refresh": "F5",
        "quit": "Ctrl+Q"
    },
    "sound": {
        "enabled": true,
        "critical_only": true
    },
    "regex_patterns": {
        "alarm_type": {
            "타임아웃": "\\[티머니\\]\\s*타임아웃\\s*발생",
            "지연응답": "\\[티머니\\]\\s*지연응답\\s*발생",
            "회원사장애": "\\[티머니\\]\\s*회원사장애\\s*발생",
            "중복거절": "\\[티머니\\]\\s*(중복거절 발생|알람\\s*\\n.*제목\\s*:\\s*중복거절)",
            "배치": "\\[티머니\\]\\s*배치프로그램 점검",
            "SAF": "\\[티머니\\]\\s*SAF\\s*확인",
            "0800무응답": "\\[티머니\\]\\s*0800전문\\s*무응답",
            "0800정상화": "\\[티머니\\]\\s*0800전문\\s*정상화",
            "프로세스중단": "\\[티머니\\]\\s*프로세스\\s*Queue\\s*Read\\s*중단",
            "프로세스정상화": "\\[티머니\\]\\s*프로세스\\s*Queue\\s*Read\\s*정상화",
            "대행승인": "\\[티머니\\]\\s*대행승인\\s*발생",
            "core파일": "\\[티머니\\]\\s*core파일\\s*확인"
        },
        "org_code": {
            "KBC": "카드사\\(KBC\\)",
            "BCC": "카드사\\(BCC\\)",
            "HDC": "카드사\\(HDC\\)",
            "SHC": "카드사\\(SHC\\)",
            "HNC": "카드사\\(HNC\\)|카드사\\(NHN-C\\)|카드사\\(HN-C\\)",
            "SSC": "카드사\\(SSC\\)|카드사\\(Samsung\\)",
            "NCV": "카드사\\(NCV\\)",
            "WRC": "카드사\\(WRC\\)|카드사\\(우리\\)",
            "KEC": "카드사\\(KEC\\)|카드사\\(기업\\)",
            "LTC": "카드사\\(LTC\\)",
            "CNS": "카드사\\(CNS\\)"
        },
        "time": "(3\\.\\s*일시\\s*:\\s*|일시\\s*:\\s*)([^\\n]+)",
        "details": "2\\.\\s*내용\\s*:\\s*([^\\n]+)"
    },
    "severity_mapping": {
        "타임아웃": "심각",
        "지연응답": "주의",
        "회원사장애": "경고",
        "중복거절": "주의",
        "배치": "경고",
        "SAF": "경고",
        "0800무응답": "심각",
        "0800정상화": "정상",
        "프로세스중단": "심각",
        "프로세스정상화": "정상",
        "대행승인": "주의",
        "core파일": "심각"
    }
}
